{
    "name": "access-board",
    "version": "0.2.0",
    "type": "module",
    "description": "Turmag's reusable access-board",
    "author": "Pavel Vinogradov",
    "license": "MIT",
    "files": [
        "dist"
    ],
    "main": "./dist/vue-access-board.umd.cjs",
    "module": "./dist/vue-access-board.js",
    "exports": {
        ".": {
            "import": "./dist/vue-access-board.js",
            "require": "./dist/vue-access-board.umd.cjs"
        },
        "./style.css": "./dist/vue-access-board.css"
    },
    "keywords": [
        "access",
        "board",
        "typescript",
        "vue"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "generate-icons-idx": "node .\\node-files\\generateIconsIndex.js",
        "generate-components-idx": "node .\\/node-files\\/generateComponentsIndex.js",
        "df": "scp -r files/* u2250830@37.140.192.227:./www/focusinfo.ru/access-board/files",
        "dapiControllers": "scp -r api/controllers/* u2250830@37.140.192.227:./www/focusinfo.ru/access-board/api/controllers",
        "dapiVendor": "scp -r api/vendor/autoload.php u2250830@37.140.192.227:./www/focusinfo.ru/access-board/api/vendor/autoload.php",
        "dapiOther": "scp -r api/*.php u2250830@37.140.192.227:./www/focusinfo.ru/access-board/api",
        "dapiHtaccess": "scp -r api/.htaccess u2250830@37.140.192.227:./www/focusinfo.ru/access-board/api",
        "dapi": "yarn dapiControllers && yarn dapiOther",
        "deploy": "scp -r dist/* u2250830@37.140.192.227:./www/focusinfo.ru/access-board",
        "bd": "yarn build && yarn deploy"
    },
    "dependencies": {
        "@kyvg/vue3-notification": "^2.9.1",
        "@vueuse/core": "^12.4.0",
        "axios": "^1.7.9",
        "jwt-decode": "^4.0.0",
        "pinia": "^2.1.3",
        "sass": "^1.83.4",
        "vue": "^3.5.13",
        "vue-multiselect": "^3.0.0-beta.3",
        "vue-router": "^4.1.5",
        "vue-tippy": "^6.7.1"
    },
    "devDependencies": {
        "@types/node": "^20.11.17",
        "@vitejs/plugin-vue": "^3.1.0",
        "eslint": "^9.15.0",
        "oxlint": "^1.39.0",
        "postcss-html": "^1.6.0",
        "stylelint": "^16.11.0",
        "turmag-eslint-config": "^2.0.70",
        "turmag-stylelint-config": "^0.0.11",
        "typescript": "^5.7.3",
        "vite": "^7.3.1"
    }
}
